{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MDParcel Editor",
  "version": "0.1.0",
  "identifier": "com.mdparcel.reader",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run frontend:dev",
    "beforeBuildCommand": "npm run frontend:build"
  },
  "app": {
    "windows": [{ "title": "MDParcel Editor", "width": 1200, "height": 780, "minWidth": 780, "minHeight": 540 }],
    "security": { "csp": "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data:;" }
  },
  "bundle": { "active": true, "targets": "all", "icon": ["icons/icon.ico"] }
}
